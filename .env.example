NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Used by /admin/[secret] routes
ADMIN_SECRET=

# Vercel cron + GitHub workflow dispatch for ESPN leaderboard sync
CRON_SECRET=
GITHUB_WORKFLOW_TOKEN=
GITHUB_REPOSITORY=

# Vercel: add the same variables in Project Settings → Environment Variables (do not expose the service role to the browser).

# --- Google sign-in (Supabase Auth) ---
# In Supabase Dashboard: Authentication → Providers → Google: enable and paste Web client ID + secret from Google Cloud Console.
# Google Cloud Console: APIs & Services → Credentials → OAuth 2.0 Client ID (Web). Authorized redirect URIs must include:
#   https://<project-ref>.supabase.co/auth/v1/callback
# Supabase: Authentication → URL configuration → Site URL = your app origin (e.g. http://localhost:3000 or https://your-domain.com).
# Add the same origin to Redirect URLs, plus http://localhost:3000/auth/callback and production https://your-domain.com/auth/callback if you list explicit paths.

